{
  "name": "@sdkwork/appstore-app-sdk",
  "version": "0.1.0",
  "description": "SDKWork App Store App SDK composed consumer facade.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated": {
      "types": "./generated/server-openapi/index.ts",
      "import": "./generated/server-openapi/index.ts",
      "default": "./generated/server-openapi/index.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}
