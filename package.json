{
  "name": "sdkwork-appstore",
  "private": true,
  "version": "0.1.0",
  "description": "SDKWork professional app store backend contracts and services",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "node ../sdkwork-specs/tools/stop-sdkwork-workspace-processes.mjs --workspace .",
    "dev": "pnpm dev:browser",
    "dev:browser": "node scripts/sdkwork-command.mjs dev --runtime-target browser --database postgres --service-layout unified-process --deployment-profile standalone --renderer desktop",
    "dev:browser:mobile": "node scripts/sdkwork-command.mjs dev --runtime-target browser --database postgres --service-layout unified-process --deployment-profile standalone --renderer mobile",
    "dev:browser:postgres:unified-process:standalone": "pnpm dev:browser",
    "build": "node scripts/sdkwork-command.mjs build",
    "preview": "node scripts/sdkwork-command.mjs preview",
    "start": "pnpm preview",
    "test": "node scripts/sdkwork-command.mjs test",
    "check": "node scripts/sdkwork-command.mjs check",
    "verify": "node scripts/sdkwork-command.mjs verify",
    "clean": "node scripts/sdkwork-command.mjs clean",
    "typecheck": "pnpm --filter sdkwork-appstore-pc exec tsc --noEmit && pnpm --filter sdkwork-appstore-h5 exec tsc --noEmit",
    "verify:rust": "cargo fmt --all --check && cargo test --workspace",
    "check:api-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace ..",
    "check:app-sdk-consumers": "node ../sdkwork-specs/tools/check-app-sdk-consumer-imports.mjs --workspace .",
    "check:pagination": "node ../sdkwork-specs/tools/check-pagination.mjs --workspace .",
    "check:tailwind-integration": "node ../sdkwork-specs/tools/check-tailwind-integration.mjs --workspace .",
    "api:materialize": "node scripts/sdkwork-command.mjs api:materialize",
    "api:materialize:check": "node scripts/sdkwork-command.mjs api:materialize:check",
    "api:check": "node scripts/sdkwork-command.mjs api:check",
    "sdk:generate": "node scripts/sdkwork-command.mjs sdk:generate",
    "sdk:generate:check": "node scripts/sdkwork-command.mjs sdk:generate:check",
    "sdk:check": "node scripts/sdkwork-command.mjs sdk:check",
    "db:materialize:contract": "node scripts/sdkwork-command.mjs db:materialize:contract",
    "db:validate": "node scripts/sdkwork-command.mjs db:validate",
    "db:plan": "node scripts/sdkwork-command.mjs db:plan",
    "db:init": "node scripts/sdkwork-command.mjs db:init",
    "db:migrate": "node scripts/sdkwork-command.mjs db:migrate",
    "db:seed": "node scripts/sdkwork-command.mjs db:seed",
    "db:status": "node scripts/sdkwork-command.mjs db:status",
    "db:drift": "node scripts/sdkwork-command.mjs db:drift",
    "db:drift:check": "node scripts/sdkwork-command.mjs db:drift:check",
    "db:bootstrap": "node scripts/sdkwork-command.mjs db:bootstrap",
    "db:postgres:plan": "node scripts/sdkwork-command.mjs db:postgres:plan",
    "db:postgres:init": "node scripts/sdkwork-command.mjs db:postgres:init",
    "db:postgres:migrate": "node scripts/sdkwork-command.mjs db:postgres:migrate",
    "topology:validate": "node scripts/sdkwork-command.mjs topology:validate",
    "topology:plan": "node scripts/sdkwork-command.mjs topology:plan",
    "gateway:package:cloud": "node scripts/sdkwork-command.mjs gateway:package:cloud",
    "gateway:validate:cloud": "node scripts/sdkwork-command.mjs gateway:validate:cloud",
    "deploy:validate": "node scripts/sdkwork-command.mjs deploy:validate",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
