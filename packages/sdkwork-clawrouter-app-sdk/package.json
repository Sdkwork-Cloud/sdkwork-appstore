{
  "name": "@sdkwork/clawrouter-app-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workspace consumer facade for sdkwork-clawrouter-app-sdk.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./domains": {
      "types": "./src/domains.ts",
      "import": "./src/domains.ts",
      "default": "./src/domains.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "workspace:*"
  }
}
